# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/functions/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/design-qa/*.png
/design-qa/*.jpg
/design-qa/*.jpeg

# next.js
/.next/
/out/

# production
/build
/functions/lib

# misc
.DS_Store
*.pem
*.key
*.p12
*.p8
*serviceAccount*.json
*firebase-adminsdk*.json
*.secret.*
.secrets/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
firebase-debug.log*

# firebase
.firebase/

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
