    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sass": "^1.100.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
