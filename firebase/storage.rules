rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /stores/{storeId}/public/{allPaths=**} {
      allow read: if true;
      // TODO_SECURITY: para produção, espelhar roles por loja em customClaims ou usar upload via Cloud Function.
      allow write: if request.auth != null && request.auth.token.platformAdmin == true;
    }

    match /stores/{storeId}/private/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.token.platformAdmin == true;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
